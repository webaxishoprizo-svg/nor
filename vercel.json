{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "public/**",
        "database.sqlite",
        "controllers/**",
        "models/**",
        "routes/**",
        "utils/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!public/).*)",
      "destination": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
